  "keyFeatures": [
    "Declarative animation API with Motion components",
    "Gesture support for drag, tap, hover, and pan interactions",
    "Motion values for reactive, performance-optimized animations",
    "AnimatePresence for mount/unmount animations",
    "Shared layout animations and transitions",
    "Spring physics and keyframe animations",
    "Viewport and element scroll animations",
    "TypeScript support with full type definitions"
  ],
  "publicApiSurface": [
    "Motion / motion - Main animation component factory",
    "M / m - Minimal animation component",
    "AnimatePresence - Mount/unmount animation wrapper",
    "AnimateSharedLayout - Shared layout animation provider",
    "MotionConfig - Configuration provider",
    "LazyMotion - Lazy-load animation features",
    "motionValue() - Create motion value",
    "useMotionValue() - Motion value hook",
    "useTransform() - Transform motion values",
    "useSpring() - Spring animation hook",
    "useVelocity() - Track value velocity",
    "useElementScroll() - Element scroll values",
    "useViewportScroll() - Viewport scroll values",
    "useMotionTemplate() - Template string motion values",
    "animate() - Imperative animation function",
    "animationControls() - Create animation controls",
    "useAnimation() - Animation controls hook",
    "useDragControls() - Drag controls hook",
    "usePresence() - Presence detection hook",
    "useIsPresent() - Check if component is present",
    "useReducedMotion() - Detect reduced motion preference",
    "useCycle() - Cycle through values",
    "transform() - Value transformation utility",
    "MotionValue - Motion value class"
  ]
